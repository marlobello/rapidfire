<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/menu_background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/menu_text"
        app:title="@string/settings"
        app:titleTextColor="@color/menu_text"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/content_padding">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sound_enabled"
            android:textColor="@color/menu_text"
            android:checked="true"
            android:layout_marginBottom="@dimen/section_spacing" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="@dimen/section_spacing" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about"
            android:textColor="@color/menu_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/element_spacing" />

        <TextView
            android:id="@+id/tvAbout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="@dimen/element_spacing" />

        <TextView
            android:id="@+id/tvGithub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_github"
            android:textColor="@color/menu_button"
            android:textSize="14sp"
            android:layout_marginBottom="@dimen/text_spacing" />

        <TextView
            android:id="@+id/tvLicense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_license"
            android:textColor="@color/menu_button"
            android:textSize="14sp"
            android:layout_marginBottom="@dimen/screen_padding" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="@dimen/section_spacing" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckUpdates"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/check_for_updates"
            android:textColor="@color/menu_text"
            app:strokeColor="@color/stroke_subtle"
            app:icon="@android:drawable/stat_sys_download"
            app:iconTint="@color/menu_text" />

        <TextView
            android:id="@+id/tvUpdateStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="@dimen/element_spacing"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
